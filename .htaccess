RewriteEngine On
Options -MultiViews


# Force HTTPS and remove WWW (Automatically works on live domain only)
RewriteCond %{HTTP_HOST} jagantechnicalservices\.ae$ [NC]
RewriteCond %{HTTPS} off [OR]
RewriteCond %{HTTP_HOST} ^www\. [NC]
RewriteRule ^(.*)$ https://jagantechnicalservices.ae/$1 [L,R=301]

# Redirect trailing slashes
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)/$ /$1 [L,R=301]

# Hide .php extension
# To internally redirect /dir/foo to /dir/foo.php
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.php -f
RewriteRule ^(.*)$ $1.php [L]

# Redirect direct .php requests to the extensionless version
# e.g., redirect /about.php to /about
RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /([a-zA-Z0-9_-]+)\.php\ HTTP
RewriteRule ^(.*)\.php$ /$1 [R=301,L]
